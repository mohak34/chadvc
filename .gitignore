# .gitignore for ChadVC

# Go
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
go.work

# Binary
server/chadvc-server
server/chadvc

# Dependency directories
vendor/

# Go workspace file
go.work.sum

# Environment variables
.env
.env.local
.env.*.local

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Logs
*.log
logs/

# Database
*.db
*.sqlite

# Node.js / Frontend
node_modules/
dist/
dist-electron/
dist-ssr/
*.local

# Build outputs
*.deb
*.AppImage
*.dmg
*.app
*.msi

# Temporary files
tmp/
temp/
